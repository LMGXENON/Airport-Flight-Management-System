# Database Configuration (RDS)
DB_SERVER=your-rds-instance.123456789.us-east-1.rds.amazonaws.com
DB_NAME=afms_production
DB_USER=admin
DB_PASSWORD=YourSecurePassword123!

# AeroDataBox API
AERODATABOX_API_KEY=your_api_key_here
AERODATABOX_API_HOST=aerodatabox.p.rapidapi.com
DEFAULT_AIRPORT=EGLL

