@model AFMS.Models.FlightIndexViewModel

@{
    ViewData["Title"] = "All Flights";
    var pagination = Model.Pagination;
}

<!-- Page Header -->
<div class="page-header page-header--split">
    <div>
        <h1 class="page-title">Managed Flights</h1>
        <p class="page-subtitle">Search, edit or remove flights. Changes appear live on the dashboard.</p>
    </div>
    <a href="@Url.Action("Add", "Flight")" class="btn-primary flight-add-btn">
        + Add New Flight
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="flight-success-banner" aria-live="polite">
        @TempData["SuccessMessage"]
    </div>
}

<!-- Flight Number Search -->
<form method="get" action="@Url.Action("Index", "Flight")" class="flight-search-form" aria-label="Search flights by flight number">
    <input type="text"
           name="search"
           value="@Model.Search"
           placeholder="e.g. BA123, search by flight number..."
           class="flight-search-input" />
    <button type="submit"
            class="flight-search-submit">
        Search
    </button>
    @if (!string.IsNullOrEmpty(Model.Search))
    {
        <a href="@Url.Action("Index", "Flight")"
           class="flight-search-clear">
            Clear
        </a>
    }
</form>

<!-- Flights Section -->
<div class="flights-section" style="position: relative;">
    <!-- Loading Spinner Overlay -->
    <div id="flightsLoadingSpinner" class="loading-spinner-overlay" style="display: none;">
        <div class="loading-spinner"></div>
        <span class="loading-spinner-label">Loading flights…</span>
    </div>
    <div class="table-wrapper">
        <table class="flights-table" aria-label="List of managed flights">
            <thead>
                <tr>
                    <th scope="col">Flight #</th>
                    <th scope="col">Airline</th>
                    <th scope="col">Destination</th>
                    <th scope="col">Aircraft</th>
                    <th scope="col">Departure</th>
                    <th scope="col">Arrival</th>
                    <th scope="col">Gate</th>
                    <th scope="col">Terminal</th>
                    <th scope="col">Status</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var flight in Model.Flights)
                {
                    var statusClass = FlightFormattingHelpers.GetStatusClass(flight.Status);
                    var statusLabel = FlightFormattingHelpers.GetStatusLabel(flight.Status);
                    
                    <tr>
                        <td class="flight-number">@flight.FlightNumber</td>
                        <td>@flight.Airline</td>
                        <td>@flight.Destination</td>
                        <td>@(string.IsNullOrWhiteSpace(flight.AircraftType) ? "-" : flight.AircraftType)</td>
                        <td>@flight.DepartureTime.ToString("MMM dd, HH:mm")</td>
                        <td>@flight.ArrivalTime.ToString("MMM dd, HH:mm")</td>
                        <td>@(flight.Gate ?? "TBD")</td>
                        <td>Terminal @flight.Terminal</td>
                        <td>
                            <span class="status-badge @statusClass">@statusLabel</span>
                        </td>
                        <td class="actions-cell">
                            <a href="@Url.Action("Details", "Flight", new { id = flight.Id })" class="action-link view">View Flight</a>
                            <a href="@Url.Action("Edit", "Flight", new { id = flight.Id })" class="action-link edit">Edit Flight</a>
                            <a href="@Url.Action("Delete", "Flight", new { id = flight.Id })" class="action-link delete" onclick="return confirm('Are you sure you want to delete this flight?');">Delete Flight</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Flights.Any())
        {
            <div class="empty-state" aria-live="polite">
                @if (!string.IsNullOrEmpty(Model.Search))
                {
                    <p class="empty-state-title">No flights found for "@Model.Search"</p>
                    <p>Try a different flight number or <a href="@Url.Action("Index", "Flight")" class="empty-state-link">clear the search</a>.</p>
                }
                else
                {
                    <p class="empty-state-title">No flights found</p>
                    <p>Click "Add New Flight" to create your first flight.</p>
                }
            </div>
        }
    </div>

    @if (pagination.TotalCount > 0)
    {
        <div class="pagination" aria-label="Managed flights pagination">
            @if (pagination.HasPreviousPage)
            {
                <a class="page-btn"
                   asp-action="Index"
                   asp-controller="Flight"
                   asp-route-search="@Model.Search"
                   asp-route-page="@(pagination.Page - 1)">‹ Prev</a>
            }
            else
            {
                <button type="button" class="page-btn" disabled>‹ Prev</button>
            }

            @if (pagination.VisiblePages().First() > 1)
            {
                <a class="page-btn"
                   asp-action="Index"
                   asp-controller="Flight"
                   asp-route-search="@Model.Search"
                   asp-route-page="1">1</a>
                @if (pagination.VisiblePages().First() > 2)
                {
                    <span class="page-ellipsis">…</span>
                }
            }

            @foreach (var pageNumber in pagination.VisiblePages())
            {
                if (pageNumber == pagination.Page)
                {
                    <button type="button" class="page-btn active" aria-current="page" disabled>@pageNumber</button>
                }
                else
                {
                    <a class="page-btn"
                       asp-action="Index"
                       asp-controller="Flight"
                       asp-route-search="@Model.Search"
                       asp-route-page="@pageNumber">@pageNumber</a>
                }
            }

            @if (pagination.VisiblePages().Last() < pagination.TotalPages)
            {
                @if (pagination.VisiblePages().Last() < pagination.TotalPages - 1)
                {
                    <span class="page-ellipsis">…</span>
                }
                <a class="page-btn"
                   asp-action="Index"
                   asp-controller="Flight"
                   asp-route-search="@Model.Search"
                   asp-route-page="@pagination.TotalPages">@pagination.TotalPages</a>
            }

            @if (pagination.HasNextPage)
            {
                <a class="page-btn"
                   asp-action="Index"
                   asp-controller="Flight"
                   asp-route-search="@Model.Search"
                   asp-route-page="@(pagination.Page + 1)">Next ›</a>
            }
            else
            {
                <button type="button" class="page-btn" disabled>Next ›</button>
            }

            <span class="page-info">Showing @pagination.PageStart-@pagination.PageEnd of @pagination.TotalCount</span>
        </div>
    }
</div>