@model AFMS.Models.FlightIndexViewModel

@{
    ViewData["Title"] = "All Flights";
    var pagination = Model.Pagination;
}

@* Page Header *@
<div class="page-header page-header--split">
    <div>
        <h1 class="page-title" data-i18n="flight.pageTitle">Managed Flights</h1>
        <p class="page-subtitle" data-i18n="flight.pageSubtitle">Search, edit or remove flights. Changes appear live on the dashboard.</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a href="@Url.Action("Add", "Flight")" class="btn-primary flight-add-btn" data-i18n="flight.addBtn">
            + Add New Flight
        </a>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="flight-success-banner" aria-live="polite">
        @TempData["SuccessMessage"]
    </div>
}

@* Flight Number Search *@
<form method="get" action="@Url.Action("Index", "Flight")" class="flight-search-form" aria-label="Search flights by flight number">
    <input type="text"
           name="search"
           value="@Model.Search"
           placeholder="e.g. BA123, search by flight number..."
           data-i18n-placeholder="flight.phSearch"
           class="flight-search-input" />
    <button type="submit"
            class="flight-search-submit"
            data-i18n="flight.searchBtn">
        Search
    </button>
    @if (!string.IsNullOrEmpty(Model.Search))
    {
        <a href="@Url.Action("Index", "Flight")"
           class="flight-search-clear"
           aria-label="Clear search and show all flights"
           data-i18n="flight.clearSearch">
            Clear
        </a>
    }
</form>

@* Flights Section *@
<div class="flights-section" style="position: relative;">
    @* Loading Spinner Overlay *@
    <div id="flightsLoadingSpinner" class="loading-spinner-overlay" style="display: none;">
        <div class="loading-spinner"></div>
        <span class="loading-spinner-label">Loading flights…</span>
    </div>
    <div class="table-wrapper">
        <table class="flights-table" aria-label="List of managed flights">
            <thead>
                <tr>
                    <th scope="col" data-i18n="flight.colNum">Flight #</th>
                    <th scope="col" data-i18n="flight.colAirline">Airline</th>
                    <th scope="col">Origin</th>
                    <th scope="col" data-i18n="flight.colDest">Destination</th>
                    <th scope="col" data-i18n="flight.colAircraft">Aircraft</th>
                    <th scope="col" data-i18n="flight.colDep">Departure</th>
                    <th scope="col" data-i18n="flight.colArr">Arrival</th>
                    <th scope="col" data-i18n="flight.colGate">Gate</th>
                    <th scope="col" data-i18n="flight.colTerminal">Terminal</th>
                    <th scope="col" data-i18n="flight.colStatus">Status</th>
                    <th scope="col" data-i18n="flight.colActions">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var flight in Model.Flights)
                {
                    var statusClass = FlightFormattingHelpers.GetStatusClass(flight.Status);
                    var statusLabel = FlightFormattingHelpers.GetStatusLabel(flight.Status);
                    
                    <tr>
                        <td class="flight-number">@flight.FlightNumber</td>
                        <td>@flight.Airline</td>
                        <td>@(string.IsNullOrWhiteSpace(flight.Origin) ? "-" : flight.Origin)</td>
                        <td>@flight.Destination</td>
                        <td>@(string.IsNullOrWhiteSpace(flight.AircraftType) ? "-" : flight.AircraftType)</td>
                        <td>@flight.DepartureTime.ToString("MMM dd, HH:mm")</td>
                        <td>@flight.ArrivalTime.ToString("MMM dd, HH:mm")</td>
                        <td><span class="@(string.IsNullOrWhiteSpace(flight.Gate) ? "cell-unset" : "")">@(string.IsNullOrWhiteSpace(flight.Gate) ? "—" : flight.Gate)</span></td>
                        <td>Terminal @flight.Terminal</td>
                        <td>
                            <span class="status-badge @statusClass">@statusLabel</span>
                        </td>
                        <td class="actions-cell">
                            <a href="@Url.Action("Details", "Flight", new { id = flight.Id })" class="action-link view" data-i18n="flight.viewBtn">View Flight</a>
                            @if (User.IsInRole("Admin"))
                            {
                                <a href="@Url.Action("Edit", "Flight", new { id = flight.Id })" class="action-link edit" data-i18n="flight.editBtn">Edit Flight</a>
                                <button type="button"
                                        class="action-link delete action-link-button js-open-delete-modal"
                                        data-flight-id="@flight.Id"
                                        data-flight-number="@flight.FlightNumber"
                                        data-flight-airline="@flight.Airline"
                                        data-flight-destination="@flight.Destination"
                                        data-flight-departure="@flight.DepartureTime.ToString("MMM dd, HH:mm")">
                                    Delete Flight
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

            @if (!Model.Flights.Any())
            {
                <div class="empty-state" aria-live="polite">
                    @if (!string.IsNullOrEmpty(Model.Search))
                    {
                        <p class="empty-state-title" data-i18n="flight.noFlights">No flights found</p>
                        <p>Try a different flight number or <a href="@Url.Action("Index", "Flight")" class="empty-state-link" data-i18n="flight.clearSearch">Clear</a>.</p>
                    }
                    else
                    {
                        <p class="empty-state-title" data-i18n="flight.noFlights">No flights found</p>
                        @if (User.IsInRole("Admin"))
                        {
                            <p data-i18n="flight.addFirst">Click "Add New Flight" to create your first flight.</p>
                        }
                    }
                </div>
            }
    </div>

    @if (pagination.TotalCount > 0)
    {
        <nav class="pagination" aria-label="Managed flights pagination">
            @* Previous button *@
            @if (pagination.HasPreviousPage)
            {
                <a class="page-btn" href="@Url.Action("Index", "Flight", new { search = Model.Search, page = pagination.Page - 1 })">‹ Prev</a>
            }
            else
            {
                <button type="button" class="page-btn" disabled>‹ Prev</button>
            }

            @* First page and ellipsis *@
            @if (pagination.VisiblePages().First() > 1)
            {
                <a class="page-btn" href="@Url.Action("Index", "Flight", new { search = Model.Search, page = 1 })">1</a>
                @if (pagination.VisiblePages().First() > 2)
                {
                    <span class="page-ellipsis">…</span>
                }
            }

            @* Page numbers *@
            @foreach (var pageNumber in pagination.VisiblePages())
            {
                if (pageNumber == pagination.Page)
                {
                    <button type="button" class="page-btn active" aria-current="page" disabled>@pageNumber</button>
                }
                else
                {
                    <a class="page-btn" href="@Url.Action("Index", "Flight", new { search = Model.Search, page = pageNumber })">@pageNumber</a>
                }
            }

            @* Last page and ellipsis *@
            @if (pagination.VisiblePages().Last() < pagination.TotalPages)
            {
                if (pagination.VisiblePages().Last() < pagination.TotalPages - 1)
                {
                    <span class="page-ellipsis">…</span>
                }
                <a class="page-btn" href="@Url.Action("Index", "Flight", new { search = Model.Search, page = pagination.TotalPages })">@pagination.TotalPages</a>
            }

            @* Next button *@
            @if (pagination.HasNextPage)
            {
                <a class="page-btn" href="@Url.Action("Index", "Flight", new { search = Model.Search, page = pagination.Page + 1 })">Next ›</a>
            }
            else
            {
                <button type="button" class="page-btn" disabled>Next ›</button>
            }

            <span class="page-info">Showing @pagination.PageStart-@pagination.PageEnd of @pagination.TotalCount</span>
        </nav>
    }
</div>

@if (User.IsInRole("Admin"))
{
    <div id="deleteConfirmOverlay" class="delete-confirm-overlay" aria-hidden="true">
        <div class="delete-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="deleteConfirmTitle">
            <button type="button" class="delete-confirm-close" aria-label="Close delete confirmation">&times;</button>

            <div class="delete-confirm-header">
                <span class="delete-confirm-kicker">Confirm Delete</span>
                <h3 id="deleteConfirmTitle" class="delete-confirm-title">Delete this flight?</h3>
                <p class="delete-confirm-subtitle">You are about to remove this flight from AFMS.</p>
            </div>

            <div class="delete-confirm-warning" role="status" aria-live="polite">
                This action is permanent and cannot be undone.
            </div>

            <dl class="delete-confirm-list">
                <div class="delete-confirm-row">
                    <dt>Flight</dt>
                    <dd id="deleteConfirmFlightNumber">-</dd>
                </div>
                <div class="delete-confirm-row">
                    <dt>Airline</dt>
                    <dd id="deleteConfirmAirline">-</dd>
                </div>
                <div class="delete-confirm-row">
                    <dt>Destination</dt>
                    <dd id="deleteConfirmDestination">-</dd>
                </div>
                <div class="delete-confirm-row">
                    <dt>Departure</dt>
                    <dd id="deleteConfirmDeparture">-</dd>
                </div>
            </dl>

            <form asp-controller="Flight" asp-action="Delete" method="post" class="delete-confirm-actions">
                @Html.AntiForgeryToken()
                <input type="hidden" id="deleteConfirmFlightId" name="id" value="" />
                <button type="button" class="delete-cancel-btn">Keep Flight</button>
                <button type="submit" class="delete-submit-btn">Yes, Delete Flight</button>
            </form>
        </div>
    </div>

    <script>
        (function () {
            var overlay = document.getElementById('deleteConfirmOverlay');
            if (!overlay) return;

            var closeBtn = overlay.querySelector('.delete-confirm-close');
            var cancelBtn = overlay.querySelector('.delete-cancel-btn');
            var idInput = document.getElementById('deleteConfirmFlightId');
            var flightNumberEl = document.getElementById('deleteConfirmFlightNumber');
            var airlineEl = document.getElementById('deleteConfirmAirline');
            var destinationEl = document.getElementById('deleteConfirmDestination');
            var departureEl = document.getElementById('deleteConfirmDeparture');
            var triggers = document.querySelectorAll('.js-open-delete-modal');
            var lastTrigger = null;

            function setText(el, value) {
                if (el) el.textContent = value && value.trim() ? value : '-';
            }

            function openModal(trigger) {
                lastTrigger = trigger;
                idInput.value = trigger.getAttribute('data-flight-id') || '';
                setText(flightNumberEl, trigger.getAttribute('data-flight-number') || '');
                setText(airlineEl, trigger.getAttribute('data-flight-airline') || '');
                setText(destinationEl, trigger.getAttribute('data-flight-destination') || '');
                setText(departureEl, trigger.getAttribute('data-flight-departure') || '');

                overlay.classList.add('active');
                overlay.setAttribute('aria-hidden', 'false');
                document.body.classList.add('modal-open');
                closeBtn.focus();
            }

            function closeModal() {
                overlay.classList.remove('active');
                overlay.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('modal-open');
                if (lastTrigger) lastTrigger.focus();
            }

            triggers.forEach(function (trigger) {
                trigger.addEventListener('click', function () {
                    openModal(trigger);
                });
            });

            if (closeBtn) closeBtn.addEventListener('click', closeModal);
            if (cancelBtn) cancelBtn.addEventListener('click', closeModal);

            overlay.addEventListener('click', function (event) {
                if (event.target === overlay) closeModal();
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape' && overlay.classList.contains('active')) {
                    closeModal();
                }
            });
        })();
    </script>
}