@model AFMS.Models.FlightDetailsViewModel

@{
    ViewData["Title"] = "Flight Details";
}

<div class="page-header">
    <h1 class="page-title">Flight @Model.FlightNumber</h1>
    <p class="page-subtitle">@Model.Airline &mdash; @Model.Destination</p>
</div>

<div class="details-card">

    @* Hero: flight number + badge inline *@
    <div class="details-hero">
        <div class="details-hero-top">
            <span class="details-flight-num">@Model.FlightNumber</span>
            <span class="status-badge @Model.StatusClass">@Model.StatusLabel</span>
        </div>
        <span class="details-airline">@Model.Airline</span>
        @if (Model.StatusClass == "status-delayed")
        {
            <span class="details-delay-note">
                <i class='bx bx-time-five' aria-hidden="true"></i>
                Delayed &mdash; original departure: @Model.DepartureTimeFormatted
            </span>
        }
    </div>

    @* Section 1: Route *@
    <div class="details-section">
        <h3 class="details-section-title">
            <i class='bx bx-map' aria-hidden="true"></i> Route
        </h3>
        <div class="details-route">
            <div class="details-route-airport">
                <span class="details-route-dir-label">From</span>
                <span class="details-route-name">@(!string.IsNullOrWhiteSpace(Model.Origin) ? Model.Origin : "—")</span>
            </div>
            <div class="details-route-sep">
                <div class="details-route-line"></div>
                <i class='bx bxs-plane-alt' aria-hidden="true"></i>
                <div class="details-route-line"></div>
            </div>
            <div class="details-route-airport details-route-airport--dest">
                <span class="details-route-dir-label">To</span>
                <span class="details-route-name">@Model.Destination</span>
            </div>
        </div>
    </div>

    @* Section 2: Timing *@
    <div class="details-section">
        <h3 class="details-section-title">
            <i class='bx bx-time' aria-hidden="true"></i> Timing
        </h3>
        <div class="details-timing-grid">
            <div class="details-timing-item">
                <span class="details-timing-label">Departure</span>
                <span class="details-timing-value">@Model.DepartureTimeFormatted</span>
            </div>
            <div class="details-timing-item details-timing-item--center">
                <span class="details-timing-label">Duration</span>
                <span class="details-timing-value details-timing-value--pill">@Model.FlightDuration</span>
            </div>
            <div class="details-timing-item details-timing-item--right">
                <span class="details-timing-label">Arrival</span>
                <span class="details-timing-value">@Model.ArrivalTimeFormatted</span>
            </div>
        </div>
    </div>

    @* Section 3: Operations *@
    <div class="details-section">
        <h3 class="details-section-title">
            <i class='bx bx-briefcase' aria-hidden="true"></i> Operations
        </h3>
        <div class="details-logistics-grid">
            @{
                bool gateSet     = !string.IsNullOrWhiteSpace(Model.FormattedGate)  && Model.FormattedGate  != "TBD" && Model.FormattedGate  != "-";
                bool terminalSet = !string.IsNullOrWhiteSpace(Model.FormattedTerminal) && Model.FormattedTerminal != "TBD" && Model.FormattedTerminal != "-";
                bool aircraftSet = !string.IsNullOrWhiteSpace(Model.AircraftType)   && Model.AircraftType   != "TBD" && Model.AircraftType   != "-";
            }
            <div class="details-logistics-item">
                <span class="details-logistics-label">
                    <i class='bx bx-door-open' aria-hidden="true"></i> Gate
                </span>
                @if (gateSet)
                {
                    <span class="details-logistics-value">@Model.FormattedGate</span>
                }
                else
                {
                    <span class="details-logistics-value details-logistics-value--unset">Not assigned</span>
                }
            </div>
            <div class="details-logistics-item">
                <span class="details-logistics-label">
                    <i class='bx bx-building' aria-hidden="true"></i> Terminal
                </span>
                @if (terminalSet)
                {
                    <span class="details-logistics-value">@Model.FormattedTerminal</span>
                }
                else
                {
                    <span class="details-logistics-value details-logistics-value--unset">Not assigned</span>
                }
            </div>
            <div class="details-logistics-item">
                <span class="details-logistics-label">
                    <i class='bx bxs-plane-alt' aria-hidden="true"></i> Aircraft
                </span>
                @if (aircraftSet)
                {
                    <span class="details-logistics-value">@Model.AircraftType</span>
                }
                else
                {
                    <span class="details-logistics-value details-logistics-value--unset">Not specified</span>
                }
            </div>
        </div>
    </div>

</div>@* /.details-card *@

@if (User.IsInRole("Admin"))
{
    <div class="detail-actions">
        <a href="@Url.Action("Edit", "Flight", new { id = Model.Id })" class="btn btn-warning">
            <i class='bx bx-edit-alt' aria-hidden="true"></i> Edit Flight
        </a>
        <button type="button" id="openDeleteConfirmFromDetails" class="btn btn-danger">
            <i class='bx bx-trash' aria-hidden="true"></i> Delete Flight
        </button>
    </div>

    <div id="deleteConfirmOverlay" class="delete-confirm-overlay" aria-hidden="true">
        <div class="delete-confirm-modal" role="dialog" aria-modal="true" aria-labelledby="deleteConfirmTitle">
            <button type="button" class="delete-confirm-close" aria-label="Close delete confirmation">&times;</button>

            <div class="delete-confirm-header">
                <span class="delete-confirm-kicker">Confirm Delete</span>
                <h3 id="deleteConfirmTitle" class="delete-confirm-title">Delete this flight?</h3>
                <p class="delete-confirm-subtitle">You are about to remove this flight from AFMS.</p>
            </div>

            <div class="delete-confirm-warning" role="status" aria-live="polite">
                This action is permanent and cannot be undone.
            </div>

            <dl class="delete-confirm-list">
                <div class="delete-confirm-row">
                    <dt>Flight</dt>
                    <dd>@Model.FlightNumber</dd>
                </div>
                <div class="delete-confirm-row">
                    <dt>Airline</dt>
                    <dd>@Model.Airline</dd>
                </div>
                <div class="delete-confirm-row">
                    <dt>Destination</dt>
                    <dd>@Model.Destination</dd>
                </div>
                <div class="delete-confirm-row">
                    <dt>Departure</dt>
                    <dd>@Model.DepartureTimeFormatted</dd>
                </div>
            </dl>

            <form asp-controller="Flight" asp-action="Delete" method="post" class="delete-confirm-actions">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="button" class="delete-cancel-btn">Keep Flight</button>
                <button type="submit" class="delete-submit-btn">Yes, Delete Flight</button>
            </form>
        </div>
    </div>
}

@section Styles {
    <link rel="stylesheet" href="~/css/add-flight.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        (function () {
            var overlay = document.getElementById('deleteConfirmOverlay');
            var openBtn = document.getElementById('openDeleteConfirmFromDetails');
            if (!overlay || !openBtn) return;

            var closeBtn = overlay.querySelector('.delete-confirm-close');
            var cancelBtn = overlay.querySelector('.delete-cancel-btn');

            function openModal() {
                overlay.classList.add('active');
                overlay.setAttribute('aria-hidden', 'false');
                document.body.classList.add('modal-open');
                if (closeBtn) closeBtn.focus();
            }

            function closeModal() {
                overlay.classList.remove('active');
                overlay.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('modal-open');
                openBtn.focus();
            }

            openBtn.addEventListener('click', openModal);
            if (closeBtn) closeBtn.addEventListener('click', closeModal);
            if (cancelBtn) cancelBtn.addEventListener('click', closeModal);

            overlay.addEventListener('click', function (event) {
                if (event.target === overlay) closeModal();
            });

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape' && overlay.classList.contains('active')) {
                    closeModal();
                }
            });
        })();
    </script>
}
