@model AFMS.Models.Flight

@{
    ViewData["Title"] = "Delete Flight";
}

<!-- Page Header -->
<div class="page-header">
    <h1 class="page-title">Delete Flight</h1>
    <p class="page-subtitle">Are you sure you want to delete this flight?</p>
</div>

<!-- Delete Confirmation Card -->
<div class="details-card">
    <div class="warning-banner">
        <strong>⚠️ Warning:</strong> This action cannot be undone. The flight will be permanently removed from the database.
    </div>

    <div class="details-grid">
        <div class="detail-item">
            <p class="detail-label">Flight Number</p>
            <p class="detail-value">@Model.FlightNumber</p>
        </div>
        
        <div class="detail-item">
            <p class="detail-label">Airline</p>
            <p class="detail-value">@Model.Airline</p>
        </div>
        
        <div class="detail-item">
            <p class="detail-label">Destination</p>
            <p class="detail-value">@Model.Destination</p>
        </div>

        <div class="detail-item">
            <p class="detail-label">Aircraft Type</p>
            <p class="detail-value">@(string.IsNullOrWhiteSpace(Model.AircraftType) ? "TBD" : Model.AircraftType)</p>
        </div>
        
        <div class="detail-item">
            <p class="detail-label">Departure Time</p>
            <p class="detail-value">@Model.DepartureTime.ToString("MMM dd, yyyy HH:mm")</p>
        </div>
    </div>
</div>

<!-- Delete Actions -->
<form asp-action="Delete" method="post" class="detail-actions">
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-danger" onclick="return confirm('Are you absolutely sure you want to delete this flight? This cannot be undone.');">
        🗑️ Confirm Delete
    </button>
    <a href="@Url.Action("Index", "Flight")" class="btn btn-secondary">
        Cancel
    </a>
</form>
