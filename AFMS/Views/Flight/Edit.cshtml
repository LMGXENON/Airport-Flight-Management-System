@model AFMS.Models.Flight

@{
    ViewData["Title"] = "Edit Flight";
}

@section Styles {
    <link rel="stylesheet" href="~/css/add-flight.css" asp-append-version="true" />
}

<div class="page-header">
    <h1 class="page-title">Edit Flight @Model.FlightNumber</h1>
    <p class="page-subtitle">Changes will appear on the dashboard immediately</p>
</div>

<div class="form-card">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="form-section">
            <h2 class="form-section-title">Flight Information</h2>
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="FlightNumber" class="form-label">Flight Number</label>
                    <input asp-for="FlightNumber" class="form-input" placeholder="e.g. BA123" />
                    <span asp-validation-for="FlightNumber" class="validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Airline" class="form-label">Airline</label>
                    <select asp-for="Airline" asp-items="ViewBag.Airlines" class="form-select">
                        <option value="">— Select Airline —</option>
                    </select>
                    <span asp-validation-for="Airline" class="validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Destination" class="form-label">Destination</label>
                    <input asp-for="Destination" class="form-input" placeholder="e.g. LAX or Los Angeles" />
                    <span asp-validation-for="Destination" class="validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Status" class="form-label">Status</label>
                    <select asp-for="Status" class="form-select">
                        @foreach (var status in FlightStatusCatalog.Options)
                        {
                            <option value="@status.Value" selected="@(Model.Status == status.Value ? "selected" : null)">@status.Label</option>
                        }
                    </select>
                    <span asp-validation-for="Status" class="validation-error"></span>
                </div>
            </div>
        </div>

        <div class="form-section">
            <h2 class="form-section-title">Timing</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label asp-for="DepartureTime" class="form-label">Departure Time</label>
                    <input asp-for="DepartureTime" type="datetime-local" class="form-input datetime-input" />
                    <span asp-validation-for="DepartureTime" class="validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="ArrivalTime" class="form-label">Arrival Time</label>
                    <input asp-for="ArrivalTime" type="datetime-local" class="form-input datetime-input" />
                    <span asp-validation-for="ArrivalTime" class="validation-error"></span>
                </div>
            </div>
        </div>

        <div class="form-section">
            <h2 class="form-section-title">Logistics</h2>
            <div class="form-grid two-columns">
                <div class="form-group">
                    <label asp-for="Gate" class="form-label">Gate</label>
                    <input asp-for="Gate" class="form-input" placeholder="e.g. B12" />
                    <span asp-validation-for="Gate" class="validation-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Terminal" class="form-label">Terminal</label>
                    <select asp-for="Terminal" class="form-select">
                        <option value="1">Terminal 1</option>
                        <option value="2">Terminal 2</option>
                        <option value="3">Terminal 3</option>
                        <option value="4">Terminal 4</option>
                        <option value="5">Terminal 5</option>
                    </select>
                    <span asp-validation-for="Terminal" class="validation-error"></span>
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Update Flight</button>
            <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
