@model AFMS.Models.AdvancedSearchViewModel

@{
    ViewData["Title"] = "Advanced Search";
}

@section Styles {
    <link rel="stylesheet" href="~/css/advanced-search.css" asp-append-version="true" />
}




<!-- Page Header -->
<div class="page-header">
    <h1 class="page-title">Advanced Flight Search</h1>
    <p class="page-subtitle">Search and filter live flight records</p>
</div>

<!-- Search Form -->
<div class="search-form-container">
    <form class="search-form" id="searchForm" method="get" asp-action="AdvancedSearch" asp-controller="Home">
        <input type="hidden" name="search" value="1" />

        <!-- Row 1: Flight, Airline, Destination -->
        <div class="form-row">
            <div class="form-group">
                <label for="flight" class="form-label">Flight Number</label>
                <input type="text" id="flight" name="flight" class="form-input"
                       placeholder="e.g., VY 5227" value="@Model.Flight" autocomplete="off" />
            </div>
            <div class="form-group">
                <label for="airline" class="form-label">Airline</label>
                <input type="text" id="airline" name="airline" class="form-input"
                       list="airlineOptions" placeholder="e.g., British Airways" value="@Model.Airline" autocomplete="off" />
                <datalist id="airlineOptions">
                    <option value="British Airways"></option>
                    <option value="Virgin Atlantic"></option>
                    <option value="easyJet"></option>
                    <option value="Ryanair"></option>
                    <option value="Emirates"></option>
                    <option value="Qatar Airways"></option>
                    <option value="Lufthansa"></option>
                    <option value="Air France"></option>
                    <option value="KLM"></option>
                    <option value="United Airlines"></option>
                    <option value="American Airlines"></option>
                    <option value="Delta Air Lines"></option>
                    <option value="Singapore Airlines"></option>
                    <option value="Cathay Pacific"></option>
                    <option value="Turkish Airlines"></option>
                    <option value="Etihad Airways"></option>
                    <option value="Swiss International Air Lines"></option>
                    <option value="Iberia"></option>
                    <option value="Finnair"></option>
                    <option value="SAS Scandinavian Airlines"></option>
                    <option value="Air Canada"></option>
                    <option value="Japan Airlines"></option>
                    <option value="ANA All Nippon Airways"></option>
                    <option value="Qantas"></option>
                    <option value="South African Airways"></option>
                </datalist>
            </div>
            <div class="form-group">
                <label for="destination" class="form-label">Destination</label>
                <input type="text" id="destination" name="destination" class="form-input"
                       list="airportOptions" placeholder="e.g., MAD or Madrid" value="@Model.Destination" autocomplete="off" />
                <datalist id="airportOptions">
                    <option value="ABV">Abuja (ABV)</option>
                    <option value="ACC">Accra (ACC)</option>
                    <option value="AMS">Amsterdam Schiphol (AMS)</option>
                    <option value="ATH">Athens Eleftherios Venizelos (ATH)</option>
                    <option value="ATL">Atlanta Hartsfield-Jackson (ATL)</option>
                    <option value="AUH">Abu Dhabi (AUH)</option>
                    <option value="AYT">Antalya (AYT)</option>
                    <option value="BCN">Barcelona El Prat (BCN)</option>
                    <option value="BEY">Beirut Rafic Hariri (BEY)</option>
                    <option value="BGW">Baghdad (BGW)</option>
                    <option value="BKK">Bangkok Suvarnabhumi (BKK)</option>
                    <option value="BLR">Bangalore (BLR)</option>
                    <option value="BOM">Mumbai (BOM)</option>
                    <option value="BOS">Boston Logan (BOS)</option>
                    <option value="BRU">Brussels (BRU)</option>
                    <option value="CAI">Cairo (CAI)</option>
                    <option value="ORD">Chicago O'Hare (ORD)</option>
                    <option value="CPT">Cape Town (CPT)</option>
                    <option value="CDG">Paris Charles de Gaulle (CDG)</option>
                    <option value="DEL">Delhi Indira Gandhi (DEL)</option>
                    <option value="DFW">Dallas/Fort Worth (DFW)</option>
                    <option value="DOH">Doha Hamad (DOH)</option>
                    <option value="DUB">Dublin (DUB)</option>
                    <option value="DXB">Dubai (DXB)</option>
                    <option value="EDI">Edinburgh (EDI)</option>
                    <option value="FCO">Rome Fiumicino (FCO)</option>
                    <option value="FRA">Frankfurt (FRA)</option>
                    <option value="GRU">São Paulo Guarulhos (GRU)</option>
                    <option value="GVA">Geneva (GVA)</option>
                    <option value="HKG">Hong Kong (HKG)</option>
                    <option value="HND">Tokyo Haneda (HND)</option>
                    <option value="IAD">Washington Dulles (IAD)</option>
                    <option value="ICN">Seoul Incheon (ICN)</option>
                    <option value="IST">Istanbul (IST)</option>
                    <option value="JFK">New York JFK (JFK)</option>
                    <option value="JNB">Johannesburg (JNB)</option>
                    <option value="KHI">Karachi (KHI)</option>
                    <option value="KUL">Kuala Lumpur (KUL)</option>
                    <option value="LAD">Luanda (LAD)</option>
                    <option value="LAX">Los Angeles (LAX)</option>
                    <option value="LGW">London Gatwick (LGW)</option>
                    <option value="LHR">London Heathrow (LHR)</option>
                    <option value="LIS">Lisbon (LIS)</option>
                    <option value="LOS">Lagos (LOS)</option>
                    <option value="MAD">Madrid Barajas (MAD)</option>
                    <option value="MAN">Manchester (MAN)</option>
                    <option value="MEX">Mexico City (MEX)</option>
                    <option value="MIA">Miami (MIA)</option>
                    <option value="MUC">Munich (MUC)</option>
                    <option value="NBO">Nairobi (NBO)</option>
                    <option value="NRT">Tokyo Narita (NRT)</option>
                    <option value="ORD">Chicago O'Hare (ORD)</option>
                    <option value="PEK">Beijing Capital (PEK)</option>
                    <option value="PHL">Philadelphia (PHL)</option>
                    <option value="PKX">Beijing Daxing (PKX)</option>
                    <option value="PVG">Shanghai Pudong (PVG)</option>
                    <option value="SFO">San Francisco (SFO)</option>
                    <option value="SIN">Singapore Changi (SIN)</option>
                    <option value="SYD">Sydney (SYD)</option>
                    <option value="TLV">Tel Aviv Ben Gurion (TLV)</option>
                    <option value="TOR">Toronto Pearson (YYZ)</option>
                    <option value="VIE">Vienna (VIE)</option>
                    <option value="YUL">Montreal Trudeau (YUL)</option>
                    <option value="YYZ">Toronto Pearson (YYZ)</option>
                    <option value="ZRH">Zurich (ZRH)</option>
                </datalist>
            </div>
        </div>

        <!-- Row 2: Departure Date, Arrival Date, Terminal -->
        <div class="form-row">
            <div class="form-group">
                <label for="departureDate" class="form-label">Departure Date</label>
                <input type="date" id="departureDate" name="departureDate" class="form-input"
                       value="@Model.DepartureDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label for="arrivalDate" class="form-label">Arrival Date</label>
                <input type="date" id="arrivalDate" name="arrivalDate" class="form-input"
                       value="@Model.ArrivalDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label for="terminal" class="form-label">Terminal</label>
                <div class="select-wrapper">
                    <select id="terminal" name="terminal" class="form-input form-select">
                        <option value="">All Terminals</option>
                        <option value="2" @(Model.Terminal == "2" ? "selected" : "")>Terminal 2</option>
                        <option value="3" @(Model.Terminal == "3" ? "selected" : "")>Terminal 3</option>
                        <option value="4" @(Model.Terminal == "4" ? "selected" : "")>Terminal 4</option>
                        <option value="5" @(Model.Terminal == "5" ? "selected" : "")>Terminal 5</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Row 3: Direction + Time Range (new) -->
        <div class="form-row">
            <div class="form-group">
                <label class="form-label">Direction</label>
                <div class="direction-toggle">
                    <input type="hidden" id="directionInput" name="direction" value="@Model.Direction" />
                    <button type="button" class="direction-btn @(string.IsNullOrEmpty(Model.Direction) ? "active" : "")"
                            data-direction="">All</button>
                    <button type="button" class="direction-btn @(Model.Direction == "Departure" ? "active" : "")"
                            data-direction="Departure">Departures</button>
                    <button type="button" class="direction-btn @(Model.Direction == "Arrival" ? "active" : "")"
                            data-direction="Arrival">Arrivals</button>
                </div>
            </div>
            <div class="form-group">
                <label for="timeRangeStart" class="form-label">From Time</label>
                <input type="time" id="timeRangeStart" name="timeRangeStart" class="form-input"
                       value="@Model.TimeRangeStart" />
            </div>
            <div class="form-group">
                <label for="timeRangeEnd" class="form-label">To Time</label>
                <input type="time" id="timeRangeEnd" name="timeRangeEnd" class="form-input"
                       value="@Model.TimeRangeEnd" />
            </div>
        </div>

        <!-- Row 4: Status Buttons (multi-select) -->
        <div class="form-row">
            <div class="form-group" style="grid-column: 1 / -1;">
                <label class="form-label">
                    Flight Status
                    <span class="form-label-hint">(select multiple)</span>
                </label>
                <div class="status-buttons" id="statusButtons">
                    @{
                        var statusOptions = new[]
                        {
                            ("Expected", "Scheduled"),
                            ("Boarding", "Boarding"),
                            ("Departed", "Departed"),
                            ("Arrived",  "Arrived"),
                            ("Delayed",  "Delayed"),
                            ("Canceled", "Cancelled"),
                        };
                        foreach (var (val, lbl) in statusOptions)
                        {
                            var isActive = Model.Statuses.Contains(val, StringComparer.OrdinalIgnoreCase);
                            <button type="button"
                                    class="status-btn @(isActive ? "active" : "")"
                                    data-status="@val">@lbl</button>
                        }
                    }
                </div>
                @foreach (var s in Model.Statuses)
                {
                    <input type="hidden" name="statuses" value="@s" class="status-hidden-input" />
                }
            </div>
        </div>

        <!-- Hidden sort/page state (for progressive enhancement) -->
        <input type="hidden" id="sortByInput"    name="sortBy"    value="@Model.SortBy" />
        <input type="hidden" id="sortOrderInput" name="sortOrder" value="@Model.SortOrder" />
        <input type="hidden" id="pageInput"      name="page"      value="1" />

        <!-- Action Buttons -->
        <div class="form-actions">
            <button type="submit" class="btn btn-primary" id="searchBtn">
                <span class="btn-icon">🔍</span>
                Search Flights
            </button>
            <button type="button" class="btn btn-secondary" id="clearFiltersBtn">
                Clear Filters
            </button>
        </div>
    </form>

    <p class="api-hint">Tip: every filter is optional — combine any number of filters together.</p>
</div>

<!-- Loading Spinner -->
<div class="search-loading" id="searchLoading" style="display:none;">
    <div class="spinner"></div>
    <span>Searching flights…</span>
</div>

<!-- Results Container (pre-rendered on first GET, then replaced via AJAX) -->
<div id="results-container">
    @if (Model.HasSearched)
    {
        @await Html.PartialAsync("_AdvancedSearchResults", Model)
    }
</div>

<!-- Flight Details Modal (shared partial) -->
@await Html.PartialAsync("_FlightDetailsModal")

@section Scripts {
    <script>
        // -------------------------------------------------------------------
        // State
        // -------------------------------------------------------------------
        let currentSortBy  = '@(Model.SortBy ?? "")';
        let currentSortOrd = '@(Model.SortOrder ?? "asc")';

        // -------------------------------------------------------------------
        // Direction toggle
        // -------------------------------------------------------------------
        const directionInput = document.getElementById('directionInput');
        document.querySelectorAll('.direction-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.querySelectorAll('.direction-btn').forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                directionInput.value = btn.dataset.direction;
            });
        });

        // -------------------------------------------------------------------
        // Status multi-select
        // -------------------------------------------------------------------
        function getSelectedStatuses() {
            return [...document.querySelectorAll('#statusButtons .status-btn.active')]
                .map(b => b.dataset.status);
        }

        document.querySelectorAll('#statusButtons .status-btn').forEach(btn => {
            btn.addEventListener('click', () => btn.classList.toggle('active'));
        });

        // -------------------------------------------------------------------
        // Build URLSearchParams from the form + current sort/page
        // -------------------------------------------------------------------
        function buildParams(page = 1, sortBy = currentSortBy, sortOrd = currentSortOrd) {
            const form   = document.getElementById('searchForm');
            const data   = new FormData(form);
            const params = new URLSearchParams();

            const skip = new Set(['search', 'statuses', 'sortBy', 'sortOrder', 'page']);
            for (const [k, v] of data.entries()) {
                if (!skip.has(k) && v) params.append(k, v);
            }

            getSelectedStatuses().forEach(s => params.append('statuses', s));

            if (sortBy)  params.set('sortBy',    sortBy);
            if (sortOrd) params.set('sortOrder', sortOrd);
            params.set('page', page);

            return params;
        }

        // -------------------------------------------------------------------
        // AJAX: replace results container
        // -------------------------------------------------------------------
        async function fetchResults(params) {
            const container = document.getElementById('results-container');
            document.getElementById('searchLoading').style.display = 'flex';
            container.style.opacity = '0.35';

            try {
                const res  = await fetch(`/Home/AdvancedSearchResults?${params}`);
                const html = await res.text();
                container.innerHTML   = html;
                container.style.opacity = '1';
                attachFlightRowHandlers();
                attachSortHandlers();
                attachLoadMoreHandler();
                currentSortBy  = params.get('sortBy')    ?? '';
                currentSortOrd = params.get('sortOrder') ?? 'asc';
            } catch (err) {
                console.error('Search failed:', err);
                container.style.opacity = '1';
            } finally {
                document.getElementById('searchLoading').style.display = 'none';
            }
        }

        // -------------------------------------------------------------------
        // AJAX: Load More (append rows, keep table intact)
        // -------------------------------------------------------------------
        async function fetchMoreResults(page) {
            const params = buildParams(page, currentSortBy, currentSortOrd);
            const btn    = document.getElementById('loadMoreBtn');
            if (btn) { btn.disabled = true; btn.textContent = 'Loading…'; }

            try {
                const res  = await fetch(`/Home/AdvancedSearchResults?${params}`);
                const html = await res.text();

                const temp = document.createElement('div');
                temp.innerHTML = html;

                // Append new rows
                const newRows = [...temp.querySelectorAll('.flights-table tbody tr')];
                const tbody   = document.querySelector('#results-container .flights-table tbody');
                if (tbody && newRows.length) {
                    newRows.forEach(r => tbody.appendChild(r));
                    attachFlightRowHandlers();
                }

                // Swap Load More section
                const newLM     = temp.querySelector('#load-more-section');
                const existingLM = document.getElementById('load-more-section');
                if (existingLM) {
                    existingLM[newLM ? 'replaceWith' : 'remove'](newLM);
                } else if (newLM) {
                    document.getElementById('results-container').appendChild(newLM);
                }

                // Update result count in header
                const newCount = temp.querySelector('.result-count');
                const oldCount = document.querySelector('#results-container .result-count');
                if (newCount && oldCount) oldCount.innerHTML = newCount.innerHTML;

                attachLoadMoreHandler();
            } catch (err) {
                console.error('Load more failed:', err);
                if (btn) { btn.disabled = false; btn.textContent = 'Load More'; }
            }
        }

        // -------------------------------------------------------------------
        // Sort headers (re-attached after each render)
        // -------------------------------------------------------------------
        function attachSortHandlers() {
            document.querySelectorAll('.sortable-th').forEach(th => {
                th.style.cursor = 'pointer';
                th.addEventListener('click', () => {
                    const col = th.dataset.col;
                    currentSortOrd = (currentSortBy === col && currentSortOrd === 'asc') ? 'desc' : 'asc';
                    currentSortBy  = col;
                    fetchResults(buildParams(1, currentSortBy, currentSortOrd));
                });
            });
        }

        // -------------------------------------------------------------------
        // Load More button (re-attached after each render)
        // -------------------------------------------------------------------
        function attachLoadMoreHandler() {
            const btn = document.getElementById('loadMoreBtn');
            if (btn) {
                btn.addEventListener('click', () => {
                    fetchMoreResults(Number(btn.dataset.page ?? 2));
                });
            }
        }

        // -------------------------------------------------------------------
        // Form submit → AJAX
        // -------------------------------------------------------------------
        document.getElementById('searchForm').addEventListener('submit', e => {
            e.preventDefault();
            currentSortBy  = '';
            currentSortOrd = 'asc';
            fetchResults(buildParams(1, '', 'asc'));
        });

        // -------------------------------------------------------------------
        // Clear filters
        // -------------------------------------------------------------------
        document.getElementById('clearFiltersBtn').addEventListener('click', () => {
            document.querySelectorAll('#statusButtons .status-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.direction-btn').forEach(b => b.classList.remove('active'));
            document.querySelector('.direction-btn[data-direction=""]').classList.add('active');
            directionInput.value = '';
            document.getElementById('searchForm').reset();
            document.getElementById('results-container').innerHTML = '';
            currentSortBy  = '';
            currentSortOrd = 'asc';
        });

        // -------------------------------------------------------------------
        // Initialise
        // -------------------------------------------------------------------
        attachSortHandlers();
        attachLoadMoreHandler();
    </script>
}
