@model List<AFMS.Models.AeroDataBoxFlight>

@{
    ViewData["Title"] = "Dashboard";

    var selectedAirportName = ViewBag.SelectedAirportName as string ?? "London Heathrow Airport";
    var selectedAirportIata = ViewBag.SelectedAirportIata as string ?? "LHR";
    var selectedAirportIcao = ViewBag.SelectedAirportIcao as string ?? "EGLL";
    var airportOptions = ViewBag.AirportOptions as IEnumerable<KeyValuePair<string, string>>
        ?? Enumerable.Empty<KeyValuePair<string, string>>();
    var lastSyncedDisplay = ViewBag.LastSyncedDisplay as string ?? "--:--";

    var apiUnavailable = ViewBag.ApiError != null;
    var totalDepartures = Model.Count(f => f.Direction == "Departure");
    var totalArrivals = Model.Count(f => f.Direction == "Arrival");
    var totalAirlines = Model.Select(f => f.Airline?.Name).Where(n => n != null).Distinct().Count();

    var totalFlightsDisplay = apiUnavailable ? "N/A" : Model.Count.ToString();
    var departuresDisplay = apiUnavailable ? "N/A" : totalDepartures.ToString();
    var arrivalsDisplay = apiUnavailable ? "N/A" : totalArrivals.ToString();
    var airlinesDisplay = apiUnavailable ? "N/A" : totalAirlines.ToString();

    var statBadgeText = apiUnavailable ? "Data Unavailable" : "Live Data";
    var statBadgeClass = apiUnavailable ? "unavailable" : "positive";
}

<!-- Page Header -->
<div class="page-header page-header--split">
    <div>
        <h1 class="page-title dashboard-title">Dashboard</h1>
        <p class="page-subtitle">@selectedAirportName (@selectedAirportIata/@selectedAirportIcao) - Live Flight Data</p>
    </div>
    <form method="get" class="airport-switcher-form" aria-label="Choose dashboard airport">
        <label for="airportSwitcher" class="airport-switcher-label">Airport</label>
        <select id="airportSwitcher" name="airport" class="airport-switcher-select" onchange="this.form.submit()">
            @foreach (var option in airportOptions)
            {
                <option value="@option.Key" selected="@(option.Key == selectedAirportIcao)">@option.Value</option>
            }
        </select>
    </form>
</div>

<!-- Stats Grid - Main -->
<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-content">
            <div class="stat-metric">
                <div class="stat-icon stat-icon--flights" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M2.5 13.2L11 11V4.7c0-1.2 1.1-2.2 2.4-2l.9.2c.9.2 1.6 1 1.6 1.9v5.6l4.3-1.1c1.2-.3 2.4.4 2.7 1.5.3 1.1-.4 2.2-1.6 2.5l-5.4 1.4v4.5l1.9 1.4v1.8l-3.7-1-3.7 1v-1.8l1.9-1.4v-3.4L4 17.4l-1.5-1.2V13.2z" fill="currentColor"/>
                    </svg>
                </div>
                <div>
                    <div class="stat-label">Total Flights</div>
                    <div class="stat-value stat-value-skeleton" data-final-value="@totalFlightsDisplay" aria-label="Loading total flights"></div>
                </div>
            </div>
        </div>
        <div class="stat-badge @statBadgeClass stat-badge-skeleton" data-final-text="@statBadgeText" aria-label="Loading status"></div>
    </div>

    <div class="stat-card">
        <div class="stat-content">
            <div class="stat-metric">
                <div class="stat-icon stat-icon--departures" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 3l5 5h-3v7h-4V8H7l5-5z" fill="currentColor"/>
                        <rect x="5" y="17" width="14" height="3" rx="1.5" fill="currentColor"/>
                    </svg>
                </div>
                <div>
                    <div class="stat-label">Departures</div>
                    <div class="stat-value stat-value-skeleton" data-final-value="@departuresDisplay" aria-label="Loading departures"></div>
                </div>
            </div>
        </div>
        <div class="stat-badge @statBadgeClass stat-badge-skeleton" data-final-text="@statBadgeText" aria-label="Loading status"></div>
    </div>

    <div class="stat-card">
        <div class="stat-content">
            <div class="stat-metric">
                <div class="stat-icon stat-icon--arrivals" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 21l-5-5h3V9h4v7h3l-5 5z" fill="currentColor"/>
                        <rect x="5" y="4" width="14" height="3" rx="1.5" fill="currentColor"/>
                    </svg>
                </div>
                <div>
                    <div class="stat-label">Arrivals</div>
                    <div class="stat-value stat-value-skeleton" data-final-value="@arrivalsDisplay" aria-label="Loading arrivals"></div>
                </div>
            </div>
        </div>
        <div class="stat-badge @statBadgeClass stat-badge-skeleton" data-final-text="@statBadgeText" aria-label="Loading status"></div>
    </div>

    <div class="stat-card">
        <div class="stat-content">
            <div class="stat-metric">
                <div class="stat-icon stat-icon--airlines" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 20h18v-2H3v2zm2-3h3V9H5v8zm5 0h4V5h-4v12zm6 0h3V11h-3v6z" fill="currentColor"/>
                    </svg>
                </div>
                <div>
                    <div class="stat-label">Airlines</div>
                    <div class="stat-value stat-value-skeleton" data-final-value="@airlinesDisplay" aria-label="Loading airlines"></div>
                </div>
            </div>
        </div>
        <div class="stat-badge @statBadgeClass stat-badge-skeleton" data-final-text="@statBadgeText" aria-label="Loading status"></div>
    </div>
</div>

<!-- Flights Section -->
<div class="flights-section">
    <div class="flights-header">
        <div class="section-title-wrap">
            <h2 class="section-title">Live Flights - @selectedAirportName (@selectedAirportIata)</h2>
            <span class="section-meta">Last updated @lastSyncedDisplay</span>
        </div>
        <div class="direction-filters">
            <button class="filter-btn active" data-direction="all" data-label="All">All</button>
            <button class="filter-btn" data-direction="Departure" data-label="Departures">Departures</button>
            <button class="filter-btn" data-direction="Arrival" data-label="Arrivals">Arrivals</button>
        </div>
    </div>
    <div class="table-filter-bar" role="search" aria-label="Filter flights in table">
        <input
            type="text"
            id="filterFlightNumber"
            class="table-filter-input"
            placeholder="Filter by flight number"
            aria-label="Filter by flight number" />
        <input
            type="text"
            id="filterAirline"
            class="table-filter-input"
            placeholder="Filter by airline"
            aria-label="Filter by airline" />
        <select id="filterStatus" class="table-filter-select" aria-label="Filter by status">
            <option value="">All statuses</option>
            <option value="scheduled">Scheduled</option>
            <option value="boarding">Boarding</option>
            <option value="departed">Departed</option>
            <option value="arrived">Arrived</option>
            <option value="delayed">Delayed</option>
            <option value="canceled">Canceled</option>
            <option value="in flight">In Flight</option>
            <option value="approaching">Approaching</option>
        </select>
        <button type="button" id="clearTableFilters" class="table-filter-clear">Clear</button>
    </div>
    <div class="table-wrapper">
        <table class="flights-table" id="flightsTable">
            <thead>
                <tr>
                    <th>TIME</th>
                    <th>FLIGHT</th>
                    <th class="from-col">FROM</th>
                    <th class="to-col">TO</th>
                    <th>AIRLINE</th>
                    <th>AIRCRAFT</th>
                    <th>STATUS</th>
                    <th>MANAGE</th>
                </tr>
            </thead>
            <tbody>
                @{
                    string lastDate = "";
                    var seenFlights = new HashSet<string>();
                }
                @foreach (var flight in Model)
                {
                    // Remove duplicates by flight number
                    var flightKey = $"{flight.Number}_{flight.Direction}";
                    if (seenFlights.Contains(flightKey))
                    {
                        continue;
                    }
                    seenFlights.Add(flightKey);
                    
                    var isDep = flight.Direction == "Departure";
                    // Use movement-level status: departure.status for departures, arrival.status for arrivals
                    var movementStatus = isDep ? flight.Departure?.Status : flight.Arrival?.Status;
                    var rawStatusSource = (movementStatus ?? flight.Status ?? flight.CodeshareStatus ?? "Unknown").Trim();
                    var normalizedStatus = FlightStatusCatalog.Normalize(rawStatusSource);
                    var rawStatus = rawStatusSource.ToLowerInvariant();

                    // Simplified status mapping for user-friendly display
                    var statusClass = FlightFormattingHelpers.GetStatusClass(normalizedStatus);

                    // Simplified status labels
                    var statusLabel = FlightFormattingHelpers.GetStatusLabel(normalizedStatus);

                    // Airport codes — fill in selected airport for the home leg
                    var depIata = flight.Departure?.Airport?.Iata
                        ?? (isDep ? selectedAirportIata : (flight.Departure?.Airport?.Name ?? "-"));
                    var arrIata = flight.Arrival?.Airport?.Iata
                        ?? (!isDep ? selectedAirportIata : (flight.Arrival?.Airport?.Name ?? "-"));

                    // Departure date/time with day name
                        var departureTime = FlightFormattingHelpers.FormatLocalDateTime(flight.Departure?.ScheduledTime?.Local, "ddd dd MMM HH:mm");

                    // Arrival date/time with day name
                        var arrivalTime = FlightFormattingHelpers.FormatLocalDateTime(flight.Arrival?.ScheduledTime?.Local, "ddd dd MMM HH:mm");

                    // Gate / Terminal from the LHR leg
                    var gate = "-";
                    var terminal = "-";
                    var lhrLeg = isDep ? flight.Departure : flight.Arrival;
                    if (lhrLeg != null)
                    {
                        gate = !string.IsNullOrEmpty(lhrLeg.Gate) ? lhrLeg.Gate : "-";
                        terminal = !string.IsNullOrEmpty(lhrLeg.Terminal) ? lhrLeg.Terminal : "-";
                    }

                    // Get city names and format location string
                    var depCity = flight.Departure?.Airport?.MunicipalityName ?? flight.Departure?.Airport?.ShortName ?? depIata;
                    var arrCity = flight.Arrival?.Airport?.MunicipalityName ?? flight.Arrival?.Airport?.ShortName ?? arrIata;
                    var fromLocation = $"{depCity} ({depIata})";
                    var toLocation = $"{arrCity} ({arrIata})";
                    
                    // Get aircraft info
                    var aircraftModel = flight.Aircraft?.Model ?? "";
                    var aircraftReg = flight.Aircraft?.Reg ?? "";
                    var aircraftInfo = !string.IsNullOrEmpty(aircraftModel) 
                        ? (!string.IsNullOrEmpty(aircraftReg) ? $"{aircraftModel} ({aircraftReg})" : aircraftModel)
                        : "-";
                    
                    // Get UTC times for progress calculation
                    var depUtc = flight.Departure?.ScheduledTime?.Utc ?? "";
                    var arrUtc = flight.Arrival?.ScheduledTime?.Utc ?? "";
                    var runwayDepUtc = flight.Departure?.RunwayTime?.Utc ?? "";
                    var runwayArrUtc = flight.Arrival?.RunwayTime?.Utc ?? "";
                    
                    // Get revised/predicted times if available (for better progress tracking)
                    var revisedDepUtc = flight.Departure?.RevisedTime?.Utc ?? "";
                    var revisedArrUtc = flight.Arrival?.RevisedTime?.Utc ?? "";
                    var predictedDepUtc = flight.Departure?.PredictedTime?.Utc ?? "";
                    var predictedArrUtc = flight.Arrival?.PredictedTime?.Utc ?? "";

                    // Build detailed status with time information - use raw status to determine state
                    var detailedStatus = statusLabel;
                    var hasActuallyDeparted = !string.IsNullOrEmpty(runwayDepUtc) || normalizedStatus == "Departed" || rawStatus == "enroute" || rawStatus == "approaching" || rawStatus == "gateclosed";
                    var hasActuallyArrived = !string.IsNullOrEmpty(runwayArrUtc) || rawStatus == "arrived";
                    
                    if (hasActuallyArrived)
                    {
                        if (DateTime.TryParse(runwayArrUtc, out var actArrTime))
                        {
                            detailedStatus = $"Arrived {actArrTime.ToLocalTime().ToString("HH:mm")}";
                        }
                        else
                        {
                            detailedStatus = "Arrived";
                        }
                        statusLabel = FlightFormattingHelpers.GetStatusLabel("Arrived");
                        statusClass = FlightFormattingHelpers.GetStatusClass("Arrived");
                    }
                    else if (hasActuallyDeparted && isDep)
                    {
                        if (DateTime.TryParse(runwayDepUtc, out var actDepTime))
                        {
                            detailedStatus = $"Departed {actDepTime.ToLocalTime().ToString("HH:mm")}";
                        }
                        else
                        {
                            detailedStatus = "Departed";
                        }
                        statusLabel = FlightFormattingHelpers.GetStatusLabel("Departed");
                        statusClass = FlightFormattingHelpers.GetStatusClass("Departed");
                    }
                    else if (hasActuallyDeparted && !isDep)
                    {
                        // Arrival that's in flight
                        detailedStatus = rawStatus == "approaching" ? "Approaching" : "In Flight";
                        statusLabel = detailedStatus;
                        statusClass = "status-departed";
                    }
                    else if (normalizedStatus == "Delayed")
                    {
                        detailedStatus = "Delayed";
                    }
                    else if (normalizedStatus == "Boarding")
                    {
                        detailedStatus = "Boarding";
                    }
                    else if (normalizedStatus == "Canceled")
                    {
                        detailedStatus = "Canceled";
                    }
                    
                    // Use consistent time for display and sorting (the LHR leg time)
                    var displayTime = isDep
                        ? FlightFormattingHelpers.FormatLocalTime(flight.Departure?.ScheduledTime?.Local)
                        : FlightFormattingHelpers.FormatLocalTime(flight.Arrival?.ScheduledTime?.Local);
                    var sortTime = FlightFormattingHelpers.ParseLocalDate(isDep
                        ? flight.Departure?.ScheduledTime?.Local
                        : flight.Arrival?.ScheduledTime?.Local) ?? DateTime.MaxValue;
                    var dateHeader = sortTime.ToString("dddd, MMM dd");
                    
                    // Show date header if date changed
                    if (dateHeader != lastDate)
                    {
                        lastDate = dateHeader;
                        <tr class="date-header-row">
                            <td colspan="8" class="date-header">@dateHeader</td>
                        </tr>
                    }

                    <tr data-direction="@flight.Direction" 
                        class="flight-row" 
                        data-flight-number="@flight.Number"
                        data-airline="@(flight.Airline?.Name ?? "-")"
                        data-dep-iata="@depIata"
                        data-arr-iata="@arrIata"
                        data-dep-city="@depCity"
                        data-arr-city="@arrCity"
                        data-dep-time="@departureTime"
                        data-arr-time="@arrivalTime"
                        data-dep-utc="@depUtc"
                        data-arr-utc="@arrUtc"
                        data-aircraft="@aircraftInfo"
                        data-runway-dep-utc="@runwayDepUtc"
                        data-runway-arr-utc="@runwayArrUtc"
                        data-revised-dep-utc="@revisedDepUtc"
                        data-revised-arr-utc="@revisedArrUtc"
                        data-predicted-dep-utc="@predictedDepUtc"
                        data-predicted-arr-utc="@predictedArrUtc"
                        data-raw-status="@rawStatus"
                        data-gate="@gate"
                        data-terminal="@terminal"
                        data-status-class="@statusClass"
                        data-status-label="@detailedStatus">
                        <td class="time-col">@displayTime</td>
                        <td class="flight-number">@flight.Number</td>
                        <td class="from-col">@fromLocation</td>
                        <td class="to-col">@toLocation</td>
                        <td>@(flight.Airline?.Name ?? "-")</td>
                        <td class="aircraft-col">@aircraftInfo</td>
                        <td class="status-col"><span class="status-badge @statusClass">@detailedStatus</span></td>
                        <td class="manage-col">
                            @{
                                var dbIds = ViewBag.DbFlightIds as Dictionary<string, int>;
                                var fNum  = flight.Number ?? "";
                            }
                            @if (dbIds != null && dbIds.ContainsKey(fNum))
                            {
                                var dbId = dbIds[fNum];
                                <div class="manage-actions" role="group" aria-label="Manage flight @fNum">
                                    <a href="/Flight/Edit/@dbId" class="manage-link manage-edit" title="Edit flight">
                                        <i class='bx bx-edit-alt' aria-hidden="true"></i>
                                    </a>
                                    <a href="/Flight/Delete/@dbId" class="manage-link manage-delete" title="Delete flight">
                                        <i class='bx bx-trash' aria-hidden="true"></i>
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="manage-actions" role="group" aria-label="Manage flight unavailable for @fNum">
                                    <span class="manage-link manage-edit manage-link--placeholder" aria-disabled="true" title="Edit unavailable">
                                        <i class='bx bx-edit-alt' aria-hidden="true"></i>
                                    </span>
                                    <span class="manage-link manage-delete manage-link--placeholder" aria-disabled="true" title="Delete unavailable">
                                        <i class='bx bx-trash' aria-hidden="true"></i>
                                    </span>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!Model.Any())
        {
            @if (ViewBag.ApiError != null)
            {
                <div class="empty-state">
                    <p class="empty-state-title empty-state-title--danger">Live data unavailable</p>
                    <p class="empty-state-muted">Flight data temporarily unavailable - quota resets shortly.</p>
                    <button type="button" id="retryDashboardBtn" class="empty-state-retry-btn" aria-label="Retry loading live flight data">
                        ↺ Retry
                    </button>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <p class="empty-state-title">No live flight data available</p>
                    <p class="empty-state-muted">The API did not return flights for the current time window.</p>
                </div>
            }
        }
    </div>

    <!-- Pagination -->
    <div class="pagination" id="pagination"></div>
</div>

<!-- Flight Details Modal (shared partial) -->
@await Html.PartialAsync("_FlightDetailsModal")

@section Scripts {
<script>
(function () {
    const retryBtn = document.getElementById('retryDashboardBtn');

    if (retryBtn) {
        retryBtn.addEventListener('click', function () {
            retryBtn.disabled = true;
            retryBtn.textContent = 'Retrying...';

            const retryUrl = new URL(window.location.href);
            retryUrl.searchParams.set('retry', Date.now().toString());
            window.location.assign(retryUrl.toString());
        });
    }

    const statValueEls = document.querySelectorAll('.stat-value[data-final-value]');
    const statBadgeEls = document.querySelectorAll('.stat-badge[data-final-text]');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealDelayMs = prefersReducedMotion ? 0 : 650;

    function revealStatValues() {
        statValueEls.forEach(function (el) {
            el.textContent = el.getAttribute('data-final-value') || '';
            el.classList.remove('stat-value-skeleton');
            el.removeAttribute('aria-label');
        });

        statBadgeEls.forEach(function (el) {
            el.textContent = el.getAttribute('data-final-text') || '';
            el.classList.remove('stat-badge-skeleton');
            el.removeAttribute('aria-label');
        });
    }

    window.setTimeout(revealStatValues, revealDelayMs);

    const PAGE_SIZE = 25;
    const query = new URLSearchParams(window.location.search);
    const requestedPage = Number.parseInt(query.get('page') ?? '1', 10);
    const requestedDirection = query.get('direction');
    let currentPage = Number.isFinite(requestedPage) && requestedPage > 0 ? requestedPage : 1;
    let currentDir = requestedDirection === 'Departure' || requestedDirection === 'Arrival'
        ? requestedDirection
        : 'all';

    const allRows = Array.from(document.querySelectorAll('#flightsTable tbody tr'));
    const flightRows = allRows.filter(r => r.classList.contains('flight-row'));
    const dateHeaderRows = allRows.filter(r => r.classList.contains('date-header-row'));
    const buttons = document.querySelectorAll('.filter-btn');
    const pagination = document.getElementById('pagination');
    const filterFlightNumber = document.getElementById('filterFlightNumber');
    const filterAirline = document.getElementById('filterAirline');
    const filterStatus = document.getElementById('filterStatus');
    const clearTableFilters = document.getElementById('clearTableFilters');

    function setDirectionCounts() {
        const counts = {
            all: flightRows.length,
            Departure: flightRows.filter(r => r.getAttribute('data-direction') === 'Departure').length,
            Arrival: flightRows.filter(r => r.getAttribute('data-direction') === 'Arrival').length
        };

        buttons.forEach(btn => {
            const direction = btn.getAttribute('data-direction') || 'all';
            const label = btn.getAttribute('data-label') || btn.textContent || '';
            const count = counts[direction] ?? 0;
            btn.textContent = `${label} (${count})`;
        });
    }

    function syncQueryState() {
        const nextUrl = new URL(window.location.href);
        if (currentPage > 1) nextUrl.searchParams.set('page', currentPage);
        else nextUrl.searchParams.delete('page');

        if (currentDir !== 'all') nextUrl.searchParams.set('direction', currentDir);
        else nextUrl.searchParams.delete('direction');

        window.history.replaceState({}, '', `${nextUrl.pathname}${nextUrl.search}`);
    }

    function getFilteredRows() {
        const flightQuery = (filterFlightNumber?.value || '').trim().toLowerCase();
        const airlineQuery = (filterAirline?.value || '').trim().toLowerCase();
        const statusQuery = (filterStatus?.value || '').trim().toLowerCase();

        return flightRows.filter(r => {
            if (currentDir !== 'all' && r.getAttribute('data-direction') !== currentDir) {
                return false;
            }

            const rowFlightNumber = (r.getAttribute('data-flight-number') || '').toLowerCase();
            const rowAirline = (r.getAttribute('data-airline') || '').toLowerCase();
            const rowStatusLabel = (r.getAttribute('data-status-label') || '').toLowerCase();
            const rowRawStatus = (r.getAttribute('data-raw-status') || '').toLowerCase();

            const matchesFlight = !flightQuery || rowFlightNumber.includes(flightQuery);
            const matchesAirline = !airlineQuery || rowAirline.includes(airlineQuery);
            const matchesStatus = !statusQuery || rowStatusLabel.includes(statusQuery) || rowRawStatus.includes(statusQuery);

            return matchesFlight && matchesAirline && matchesStatus;
        });
    }

    function render() {
        const filtered = getFilteredRows();
        const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
        if (currentPage > totalPages) currentPage = totalPages;

        // Hide all rows first
        flightRows.forEach(r => r.style.display = 'none');
        dateHeaderRows.forEach(r => r.style.display = 'none');

        // Show only current page flight rows
        const start = (currentPage - 1) * PAGE_SIZE;
        const end = start + PAGE_SIZE;
        const visibleFlights = filtered.slice(start, end);
        visibleFlights.forEach(r => r.style.display = '');
        
        // Re-attach click handlers after changing display
        attachFlightRowHandlers();
        
        // Show date headers if there are visible flights after them
        dateHeaderRows.forEach(header => {
            let hasVisibleFlight = false;
            let nextRow = header.nextElementSibling;
            
            while (nextRow) {
                if (nextRow.classList.contains('date-header-row')) {
                    break; // Stop at next date header
                }
                if (nextRow.classList.contains('flight-row') && nextRow.style.display !== 'none') {
                    hasVisibleFlight = true;
                    break;
                }
                nextRow = nextRow.nextElementSibling;
            }
            
            if (hasVisibleFlight) {
                header.style.display = '';
            }
        });

        // Build pagination
        let html = '';
        html += '<button class="page-btn" data-page="prev" ' + (currentPage === 1 ? 'disabled' : '') + '>‹ Prev</button>';

        const maxButtons = 7;
        let startPage = Math.max(1, currentPage - 3);
        let endPage = Math.min(totalPages, startPage + maxButtons - 1);
        if (endPage - startPage < maxButtons - 1) startPage = Math.max(1, endPage - maxButtons + 1);

        if (startPage > 1) {
            html += '<button class="page-btn" data-page="1">1</button>';
            if (startPage > 2) html += '<span class="page-ellipsis">…</span>';
        }
        for (let i = startPage; i <= endPage; i++) {
            html += '<button class="page-btn' + (i === currentPage ? ' active' : '') + '" data-page="' + i + '">' + i + '</button>';
        }
        if (endPage < totalPages) {
            if (endPage < totalPages - 1) html += '<span class="page-ellipsis">…</span>';
            html += '<button class="page-btn" data-page="' + totalPages + '">' + totalPages + '</button>';
        }

        html += '<button class="page-btn" data-page="next" ' + (currentPage === totalPages ? 'disabled' : '') + '>Next ›</button>';
        html += '<span class="page-info">Showing ' + (filtered.length ? start + 1 : 0) + '–' + Math.min(end, filtered.length) + ' of ' + filtered.length + '</span>';

        pagination.innerHTML = html;
        syncQueryState();
    }

    // Direction filter
    setDirectionCounts();

    buttons.forEach(btn => {
        btn.classList.toggle('active', btn.getAttribute('data-direction') === currentDir);
    });

    buttons.forEach(btn => {
        btn.addEventListener('click', function () {
            buttons.forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            currentDir = this.getAttribute('data-direction');
            currentPage = 1;
            render();
        });
    });

    [filterFlightNumber, filterAirline].forEach(control => {
        if (!control) return;
        control.addEventListener('input', function () {
            currentPage = 1;
            render();
        });
    });

    if (filterStatus) {
        filterStatus.addEventListener('change', function () {
            currentPage = 1;
            render();
        });
    }

    if (clearTableFilters) {
        clearTableFilters.addEventListener('click', function () {
            if (filterFlightNumber) filterFlightNumber.value = '';
            if (filterAirline) filterAirline.value = '';
            if (filterStatus) filterStatus.value = '';
            currentPage = 1;
            render();
        });
    }

    // Pagination clicks
    pagination.addEventListener('click', function (e) {
        const btn = e.target.closest('.page-btn');
        if (!btn || btn.disabled) return;
        const val = btn.getAttribute('data-page');
        if (val === 'prev') currentPage--;
        else if (val === 'next') currentPage++;
        else currentPage = parseInt(val);
        render();
        document.querySelector('.flights-section').scrollIntoView({ behavior: 'smooth' });
    });

    render();
    
    // Attach click handlers after initial render
    attachFlightRowHandlers();
})();
</script>
}
