@model AFMS.Models.AccountSettingsViewModel
@{
    ViewData["Title"] = "Settings";
}

<div class="page-header">
    <h2 class="page-title">Settings</h2>
    <p class="page-subtitle">Manage your AFMS user preferences.</p>
</div>

@if (Model.Saved)
{
    <div class="account-alert" role="status" aria-live="polite">Settings saved.</div>
}

<form asp-controller="Account" asp-action="Settings" method="post" class="account-settings-form">
    @Html.AntiForgeryToken()

    <section class="account-card account-card--wide">
        <h3 class="account-card-title">Preferences</h3>

        <div class="account-form-grid">
            <div class="account-field">
                <label for="Theme">Theme</label>
                <select id="Theme" name="Theme" class="account-select" data-setting="theme">
                    <option value="light" selected="@(Model.Theme == "light")">Light</option>
                    <option value="dark" selected="@(Model.Theme == "dark")">Dark</option>
                </select>
            </div>



            <div class="account-field">
                <label for="TimeFormat">Time format</label>
                <select id="TimeFormat" name="TimeFormat" class="account-select" data-setting="time-format">
                    <option value="24" selected="@(Model.TimeFormat == "24")">24-hour</option>
                    <option value="12" selected="@(Model.TimeFormat == "12")">12-hour</option>
                </select>
            </div>

            <div class="account-field">
                <label for="Language">Language</label>
                <select id="Language" name="Language" class="account-select">
                    <option value="en" selected="@(Model.Language == "en")">English</option>
                </select>
            </div>
        </div>

        <div class="account-actions">
            <button type="submit" class="account-save-btn">Save Settings</button>
        </div>
    </section>
</form>

@section Styles {
    <link rel="stylesheet" href="~/css/account-pages.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        (function () {
            var themeSelect     = document.getElementById('Theme');
            var timeFormatSelect = document.getElementById('TimeFormat');
            var themeToggle     = document.getElementById('themeToggle');
            var settingsForm    = document.querySelector('.account-settings-form');

            /* ── helpers ─────────────────────────────────────────── */
            function readCookie(name) {
                var match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]+)'));
                return match ? decodeURIComponent(match[1]) : null;
            }

            /* Original saved theme — never mutated until Save is clicked */
            var originalTheme = (function () {
                var ls = localStorage.getItem('afms-theme');
                if (ls === 'dark' || ls === 'light') return ls;
                var ck = readCookie('afms_theme');
                if (ck === 'dark' || ck === 'light') return ck;
                return document.body.classList.contains('dark-theme') ? 'dark' : 'light';
            })();

            /* Apply theme visually — NO localStorage write (preview only) */
            function previewTheme(theme) {
                var dark = theme === 'dark';
                document.body.classList.toggle('dark-theme', dark);
                if (themeToggle) {
                    themeToggle.setAttribute('aria-pressed', dark ? 'true' : 'false');
                    themeToggle.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
                    var icon = themeToggle.querySelector('.theme-toggle-icon');
                    if (icon) {
                        icon.classList.remove('bx-moon', 'bx-sun');
                        icon.classList.add(dark ? 'bx-sun' : 'bx-moon');
                    }
                }
            }

            function getCurrentTimeFormat() {
                var lf = localStorage.getItem('afms-time-format');
                if (lf === '12' || lf === '24') return lf;
                var cf = readCookie('afms_time_format');
                if (cf === '12' || cf === '24') return cf;
                return '24';
            }

            /* ── initialise dropdowns ────────────────────────────── */
            if (themeSelect)      themeSelect.value      = originalTheme;
            if (timeFormatSelect) timeFormatSelect.value = getCurrentTimeFormat();

            /* ── live preview on dropdown change ────────────────── */
            if (themeSelect) {
                themeSelect.addEventListener('change', function () {
                    previewTheme(themeSelect.value);
                });
            }

            /* ── commit to localStorage only on Save ─────────────── */
            if (settingsForm) {
                settingsForm.addEventListener('submit', function () {
                    if (themeSelect) {
                        localStorage.setItem('afms-theme', themeSelect.value);
                    }
                });
            }

            if (typeof updateClock === 'function') {
                updateClock();
            }
        })();
    </script>
}
