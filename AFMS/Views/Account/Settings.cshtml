@model AFMS.Models.AccountSettingsViewModel
@{
    ViewData["Title"] = "Settings";
}

<div class="page-header">
    <h2 class="page-title" data-i18n="settings.title">Settings</h2>
    <p class="page-subtitle" data-i18n="settings.subtitle">Manage your AFMS user preferences.</p>
</div>

@if (Model.Saved)
{
    <div class="account-alert" role="status" aria-live="polite" data-i18n="settings.saved">Settings saved.</div>
}

<form asp-controller="Account" asp-action="Settings" method="post" class="account-settings-form">
    @Html.AntiForgeryToken()

    <div class="settings-sections">

        @* Section 1: Appearance *@
        <section class="settings-section">
            <div class="settings-section-header">
                <div class="settings-section-icon settings-section-icon--appearance">
                    <i class='bx bx-palette' aria-hidden="true"></i>
                </div>
                <div class="settings-section-meta">
                    <h3 class="settings-section-title">Appearance</h3>
                    <p class="settings-section-desc">Customise how AFMS looks and displays data across all pages.</p>
                </div>
            </div>

            <div class="account-form-grid settings-form-grid">
                <div class="account-field">
                    <label for="Theme" data-i18n="settings.theme">Theme</label>
                    <select id="Theme" name="Theme" class="account-select" data-setting="theme">
                        <option value="light" selected="@(Model.Theme == "light")" data-i18n="settings.themeLight">Light</option>
                        <option value="dark"  selected="@(Model.Theme == "dark")"  data-i18n="settings.themeDark">Dark</option>
                    </select>
                </div>

                <div class="account-field">
                    <label for="TimeFormat" data-i18n="settings.timeFormat">Time format</label>
                    <select id="TimeFormat" name="TimeFormat" class="account-select" data-setting="time-format">
                        <option value="24" selected="@(Model.TimeFormat == "24")" data-i18n="settings.time24">24-hour</option>
                        <option value="12" selected="@(Model.TimeFormat == "12")" data-i18n="settings.time12">12-hour</option>
                    </select>
                </div>

                <div class="account-field">
                    <label for="Language" data-i18n="settings.language">Language</label>
                    <select id="Language" name="Language" class="account-select">
                        <option value="en" selected="@(Model.Language == "en")" data-i18n="settings.langEn">English</option>
                        <option value="es" selected="@(Model.Language == "es")" data-i18n="settings.langEs">Spanish</option>
                        <option value="fr" selected="@(Model.Language == "fr")" data-i18n="settings.langFr">French</option>
                        <option value="pl" selected="@(Model.Language == "pl")" data-i18n="settings.langPl">Polish</option>
                        <option value="ro" selected="@(Model.Language == "ro")" data-i18n="settings.langRo">Romanian</option>
                        <option value="pa" selected="@(Model.Language == "pa")" data-i18n="settings.langPa">Punjabi</option>
                    </select>
                </div>
            </div>
        </section>

        @* Section 2: Airport *@
        <section class="settings-section settings-section--locked">
            <div class="settings-section-header">
                <div class="settings-section-icon settings-section-icon--airport">
                    <i class='bx bxs-plane-alt' aria-hidden="true"></i>
                </div>
                <div class="settings-section-meta">
                    <h3 class="settings-section-title">
                        Airport Hub
                        <span class="settings-badge settings-badge--fixed">Fixed</span>
                    </h3>
                    <p class="settings-section-desc">Your active airport. Multi-airport selection is planned for a future release.</p>
                </div>
            </div>

            <div class="settings-airport-card">
                <div class="settings-airport-codes">
                    <span class="settings-airport-iata">LHR</span>
                    <span class="settings-airport-icao">EGLL</span>
                </div>
                <div class="settings-airport-info">
                    <span class="settings-airport-name">London Heathrow Airport</span>
                    <span class="settings-airport-meta">
                        <i class='bx bx-globe' aria-hidden="true"></i> Europe/London &nbsp;·&nbsp;
                        <i class='bx bx-flag' aria-hidden="true"></i> United Kingdom &nbsp;·&nbsp;
                        <i class='bx bx-time' aria-hidden="true"></i> GMT+1
                    </span>
                </div>
                <i class='bx bx-lock-alt settings-airport-lock' aria-label="Airport locked" aria-hidden="true"></i>
            </div>

            <p class="settings-future-note">
                <i class='bx bx-info-circle' aria-hidden="true"></i>
                Support for additional airports (Gatwick, Stansted, JFK, LAX) is on the roadmap.
            </p>
        </section>

        @* Section 3: Notifications *@
        <section class="settings-section settings-section--locked">
            <div class="settings-section-header">
                <div class="settings-section-icon settings-section-icon--notify">
                    <i class='bx bx-bell' aria-hidden="true"></i>
                </div>
                <div class="settings-section-meta">
                    <h3 class="settings-section-title">
                        Notifications
                        <span class="settings-badge settings-badge--soon">Coming Soon</span>
                    </h3>
                    <p class="settings-section-desc">Receive real-time alerts for gate changes, delays, and departures.</p>
                </div>
            </div>

            <div class="settings-toggles">
                <div class="settings-toggle-row" aria-disabled="true">
                    <div class="settings-toggle-info">
                        <span class="settings-toggle-label">Gate change alerts</span>
                        <span class="settings-toggle-hint">Notify when a flight's gate is reassigned</span>
                    </div>
                    <div class="settings-toggle-switch settings-toggle-switch--disabled" aria-hidden="true">
                        <span class="settings-toggle-knob"></span>
                    </div>
                </div>

                <div class="settings-toggle-row" aria-disabled="true">
                    <div class="settings-toggle-info">
                        <span class="settings-toggle-label">Delay notifications</span>
                        <span class="settings-toggle-hint">Alert when a departure or arrival is delayed</span>
                    </div>
                    <div class="settings-toggle-switch settings-toggle-switch--disabled" aria-hidden="true">
                        <span class="settings-toggle-knob"></span>
                    </div>
                </div>

                <div class="settings-toggle-row" aria-disabled="true">
                    <div class="settings-toggle-info">
                        <span class="settings-toggle-label">Departure reminders</span>
                        <span class="settings-toggle-hint">Reminder 30 minutes before scheduled departure</span>
                    </div>
                    <div class="settings-toggle-switch settings-toggle-switch--disabled" aria-hidden="true">
                        <span class="settings-toggle-knob"></span>
                    </div>
                </div>
            </div>
        </section>

    </div>@* /.settings-sections *@

    @* Sticky save footer *@
    <div class="settings-form-footer">
        <p class="settings-save-hint">Only <strong>Appearance</strong> preferences are saved.</p>
        <button type="submit" class="account-save-btn" data-i18n="settings.saveBtn">Save Settings</button>
    </div>

</form>

@section Styles {
    <link rel="stylesheet" href="~/css/account-pages.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        (function () {
            var themeSelect = document.getElementById('Theme');
            var timeFormatSelect = document.getElementById('TimeFormat');
            var langSelect = document.getElementById('Language');
            var themeToggle = document.getElementById('themeToggle');
            var settingsForm = document.querySelector('.account-settings-form');

            function readCookie(name) {
                var match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]+)'));
                return match ? decodeURIComponent(match[1]) : null;
            }

            var originalTheme = (function () {
                var ls = localStorage.getItem('afms-theme');
                if (ls === 'dark' || ls === 'light') return ls;
                var ck = readCookie('afms_theme');
                if (ck === 'dark' || ck === 'light') return ck;
                return document.body.classList.contains('dark-theme') ? 'dark' : 'light';
            })();

            var originalLang = (function () {
                var ls = localStorage.getItem('afms-language');
                if (ls && window.afmsI18n && window.afmsI18n.dict[ls]) return ls;
                var ck = readCookie('afms_language');
                if (ck && window.afmsI18n && window.afmsI18n.dict[ck]) return ck;
                return 'en';
            })();

            function previewTheme(theme) {
                var dark = theme === 'dark';
                document.body.classList.toggle('dark-theme', dark);
                if (themeToggle) {
                    themeToggle.setAttribute('aria-pressed', dark ? 'true' : 'false');
                    themeToggle.setAttribute('aria-label', dark ? 'Switch to light mode' : 'Switch to dark mode');
                    var icon = themeToggle.querySelector('.theme-toggle-icon');
                    if (icon) {
                        icon.classList.remove('bx-moon', 'bx-sun');
                        icon.classList.add(dark ? 'bx-sun' : 'bx-moon');
                    }
                }
            }

            function previewLang(lang) {
                if (window.afmsI18n) {
                    window.afmsI18n.apply(lang);
                }
            }

            function getCurrentTimeFormat() {
                var lf = localStorage.getItem('afms-time-format');
                if (lf === '12' || lf === '24') return lf;
                var cf = readCookie('afms_time_format');
                if (cf === '12' || cf === '24') return cf;
                return '24';
            }

            if (themeSelect) {
                themeSelect.value = originalTheme;
            }
            if (timeFormatSelect) {
                timeFormatSelect.value = getCurrentTimeFormat();
            }
            if (langSelect) {
                langSelect.value = originalLang;
            }

            if (themeSelect) {
                themeSelect.addEventListener('change', function () { previewTheme(themeSelect.value); });
            }
            if (langSelect) {
                langSelect.addEventListener('change', function () { previewLang(langSelect.value); });
            }

            if (settingsForm) {
                settingsForm.addEventListener('submit', function () {
                    if (themeSelect) localStorage.setItem('afms-theme', themeSelect.value);
                    if (langSelect)  localStorage.setItem('afms-language', langSelect.value);
                });
            }
        })();
    </script>
}
