@model AFMS.Models.AccountProfileViewModel
@{
    ViewData["Title"] = "Profile";

    // Normalise loopback addresses to a human-readable label.
    string FriendlyIp(string? ip)
    {
        if (string.IsNullOrWhiteSpace(ip)) return "Unknown";
        if (ip is "::1" or "127.0.0.1" or "::ffff:127.0.0.1" or "localhost") return "localhost";
        return ip;
    }

    TimeZoneInfo ResolveUkTimeZone()
    {
        try { return TimeZoneInfo.FindSystemTimeZoneById("Europe/London"); }
        catch
        {
            try { return TimeZoneInfo.FindSystemTimeZoneById("GMT Standard Time"); }
            catch { return TimeZoneInfo.Utc; }
        }
    }

    string FormatUkTimestamp(DateTime utc)
    {
        var tz = ResolveUkTimeZone();
        var uk = TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(utc, DateTimeKind.Utc), tz);
        var zoneLabel = tz.IsDaylightSavingTime(uk) ? "BST" : "GMT";
        return $"{uk:yyyy-MM-dd HH:mm:ss} {zoneLabel}";
    }
}

<div class="page-header">
    <h2 class="page-title" data-i18n="profile.title">Profile</h2>
    <p class="page-subtitle" data-i18n="profile.subtitle">Your authenticated account details in AFMS.</p>
</div>

@if (Model.PasswordChanged)
{
    <div class="account-alert" role="status" aria-live="polite" data-i18n="profile.pwdChanged">Password changed successfully.</div>
}

@if (!string.IsNullOrWhiteSpace(Model.PasswordChangeError))
{
    <div class="account-alert account-alert--error" role="alert">@Model.PasswordChangeError</div>
}

<div class="account-grid">
    <section class="account-card">
        <h3 class="account-card-title" data-i18n="profile.userIdentity">User Identity</h3>
        <dl class="account-list">
            <div class="account-list-row">
                <dt data-i18n="profile.username">Username</dt>
                <dd>@Model.Username</dd>
            </div>
            <div class="account-list-row">
                <dt data-i18n="profile.role">Role</dt>
                <dd>@Model.Role</dd>
            </div>
        </dl>
    </section>

    <section class="account-card">
        <h3 class="account-card-title" data-i18n="profile.sessionSec">Session and Security</h3>
        <dl class="account-list">
            <div class="account-list-row">
                <dt data-i18n="profile.lastLogin">Last Login</dt>
                <dd>@(Model.LastLoginUtc.HasValue ? FormatUkTimestamp(Model.LastLoginUtc.Value) : "Not available yet")</dd>
            </div>
            <div class="account-list-row">
                <dt data-i18n="profile.sessionExp">Session Expires In</dt>
                <dd>
                    <span class="session-countdown" id="sessionExpiryCountdown" data-remaining-seconds="@Model.SessionRemainingSeconds">
                        @(Model.SessionRemainingSeconds > 0 ? "Calculating..." : "Expired")
                    </span>
                </dd>
            </div>
            <div class="account-list-row">
                <dt data-i18n="profile.sessionDur">Session Duration</dt>
                <dd>@Model.SessionExpiryHours <span data-i18n="profile.hours">hours</span></dd>
            </div>
            <div class="account-list-row">
                <dt data-i18n="profile.lastRefreshed">Last Refreshed</dt>
                <dd>@FormatUkTimestamp(Model.LastUpdatedUtc)</dd>
            </div>
        </dl>
    </section>

    <section class="account-card account-card--wide">
        <h3 class="account-card-title" data-i18n="profile.changePwd">Change Password</h3>
        <form asp-controller="Account" asp-action="ChangePassword" method="post" class="account-settings-form">
            @Html.AntiForgeryToken()
            <div class="account-form-grid">
                <div class="account-field">
                    <label for="CurrentPassword" data-i18n="profile.currentPwd">Current password</label>
                    <input id="CurrentPassword" name="CurrentPassword" type="password" class="account-select" required minlength="8" />
                </div>
                <div class="account-field">
                    <label for="NewPassword" data-i18n="profile.newPwd">New password</label>
                    <input id="NewPassword" name="NewPassword" type="password" class="account-select" required minlength="8" />
                </div>
                <div class="account-field">
                    <label for="ConfirmPassword" data-i18n="profile.confirmPwd">Confirm new password</label>
                    <input id="ConfirmPassword" name="ConfirmPassword" type="password" class="account-select" required minlength="8" />
                </div>
            </div>
            <div class="account-actions">
                <button type="submit" class="account-save-btn" data-i18n="profile.updatePwd">Update Password</button>
            </div>
        </form>
    </section>

    <section class="account-card account-card--wide">
        <h3 class="account-card-title" data-i18n="profile.loginHistory">Login History</h3>
        @if (Model.LoginHistory.Any())
        {
            <div class="account-history-table-wrapper">
                <table class="account-history-table">
                    <thead>
                        <tr>
                            <th>Timestamp (UK)</th>
                            <th>Device / Browser</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model.LoginHistory)
                        {
                            <tr>
                                <td>@FormatUkTimestamp(entry.OccurredUtc)</td>
                                <td>
                                    @{
                                        var displayIp = FriendlyIp(entry.IpAddress);
                                        var isLocal   = displayIp == "localhost";
                                    }
                                    <span title="IP: @displayIp">@entry.DeviceBrowser</span>
                                    @if (isLocal)
                                    {
                                        <span class="ip-local" title="IPv6 loopback — this machine">localhost</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="page-subtitle" data-i18n="profile.noHistory">No login history available yet.</p>
        }
    </section>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/account-pages.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        (function () {
            var countdownEl = document.getElementById('sessionExpiryCountdown');
            if (!countdownEl) {
                return;
            }

            var remaining = parseInt(countdownEl.getAttribute('data-remaining-seconds') || '0', 10);

            function render(seconds) {
                if (seconds <= 0) {
                    countdownEl.textContent = 'Expired';
                    return;
                }

                var hours = Math.floor(seconds / 3600);
                var minutes = Math.floor((seconds % 3600) / 60);
                countdownEl.textContent = hours + 'h ' + minutes + 'm';
            }

            render(remaining);
            setInterval(function () {
                remaining = Math.max(0, remaining - 1);
                render(remaining);
            }, 1000);
        })();
    </script>
}
