@model AFMS.Models.AccountProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<div class="page-header">
    <h2 class="page-title">Profile</h2>
    <p class="page-subtitle">Your authenticated account details in AFMS.</p>
</div>

@if (Model.PasswordChanged)
{
    <div class="account-alert" role="status" aria-live="polite">Password changed successfully.</div>
}

@if (!string.IsNullOrWhiteSpace(Model.PasswordChangeError))
{
    <div class="account-alert account-alert--error" role="alert">@Model.PasswordChangeError</div>
}

<div class="account-grid">
    <section class="account-card">
        <h3 class="account-card-title">User Identity</h3>
        <dl class="account-list">
            <div class="account-list-row">
                <dt>Username</dt>
                <dd>@Model.Username</dd>
            </div>
            <div class="account-list-row">
                <dt>Role</dt>
                <dd>@Model.Role</dd>
            </div>
        </dl>
    </section>

    <section class="account-card">
        <h3 class="account-card-title">Session and Security</h3>
        <dl class="account-list">
            <div class="account-list-row">
                <dt>Last Login</dt>
                <dd>@(Model.LastLoginUtc.HasValue ? Model.LastLoginUtc.Value.ToString("yyyy-MM-dd HH:mm:ss") + " UTC" : "Not available yet")</dd>
            </div>
            <div class="account-list-row">
                <dt>Session Expires In</dt>
                <dd>
                    <span class="session-countdown" id="sessionExpiryCountdown" data-remaining-seconds="@Model.SessionRemainingSeconds">
                        @(Model.SessionRemainingSeconds > 0 ? "Calculating..." : "Expired")
                    </span>
                </dd>
            </div>
            <div class="account-list-row">
                <dt>Session Duration</dt>
                <dd>@Model.SessionExpiryHours hours</dd>
            </div>
            <div class="account-list-row">
                <dt>Last Refreshed</dt>
                <dd>@Model.LastUpdatedUtc.ToString("yyyy-MM-dd HH:mm:ss") UTC</dd>
            </div>
        </dl>
    </section>

    <section class="account-card account-card--wide">
        <h3 class="account-card-title">Change Password</h3>
        <form asp-controller="Account" asp-action="ChangePassword" method="post" class="account-settings-form">
            @Html.AntiForgeryToken()
            <div class="account-form-grid">
                <div class="account-field">
                    <label for="CurrentPassword">Current password</label>
                    <input id="CurrentPassword" name="CurrentPassword" type="password" class="account-select" required minlength="8" />
                </div>
                <div class="account-field">
                    <label for="NewPassword">New password</label>
                    <input id="NewPassword" name="NewPassword" type="password" class="account-select" required minlength="8" />
                </div>
                <div class="account-field">
                    <label for="ConfirmPassword">Confirm new password</label>
                    <input id="ConfirmPassword" name="ConfirmPassword" type="password" class="account-select" required minlength="8" />
                </div>
            </div>
            <div class="account-actions">
                <button type="submit" class="account-save-btn">Update Password</button>
            </div>
        </form>
    </section>

    <section class="account-card account-card--wide">
        <h3 class="account-card-title">Login History</h3>
        @if (Model.LoginHistory.Any())
        {
            <div class="account-history-table-wrapper">
                <table class="account-history-table">
                    <thead>
                        <tr>
                            <th>Timestamp (UTC)</th>
                            <th>IP Address</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model.LoginHistory)
                        {
                            <tr>
                                <td>@entry.OccurredUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@entry.IpAddress</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="page-subtitle">No login history available yet.</p>
        }
    </section>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/account-pages.css" asp-append-version="true" />
}

@section Scripts {
    <script>
        (function () {
            var countdownEl = document.getElementById('sessionExpiryCountdown');
            if (!countdownEl) {
                return;
            }

            var remaining = parseInt(countdownEl.getAttribute('data-remaining-seconds') || '0', 10);

            function render(seconds) {
                if (seconds <= 0) {
                    countdownEl.textContent = 'Expired';
                    return;
                }

                var hours = Math.floor(seconds / 3600);
                var minutes = Math.floor((seconds % 3600) / 60);
                countdownEl.textContent = hours + 'h ' + minutes + 'm';
            }

            render(remaining);
            setInterval(function () {
                remaining = Math.max(0, remaining - 1);
                render(remaining);
            }, 1000);
        })();
    </script>
}
