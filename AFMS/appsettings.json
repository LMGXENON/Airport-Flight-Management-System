{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=flights.db"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DeepSeek": {
