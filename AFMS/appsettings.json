{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=flights.db"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "DeepSeek": {
    "ApiEndpoint": "https://api.deepseek.com/v1",
    "Model": "deepseek-chat",
    "PromptFile": "Prompts/DeepSeekFlightSearchPrompt.txt",
    "TimeoutSeconds": 15,
    "MaxRequestsPerMinute": 5
  },
  "Auth": {
    "AdminUsername": "afms",
    "AdminPassword": "CHANGE_IN_ENV",
    "UserUsername": "user",
    "UserPassword": "User@12345",
    "Issuer": "AFMS",
    "Audience": "AFMS.Users",
    "JwtSecret": "CHANGE_IN_ENV_USE_LONG_RANDOM_SECRET",
    "TokenExpiryHours": 8
  },
  "DataProtection": {
    "KeysPath": ""
  },
  "AllowedHosts": "*"
}
